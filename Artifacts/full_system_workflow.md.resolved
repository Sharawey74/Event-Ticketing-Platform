  │  JWT: organizer      ├─@PreAuthorize(ORGANIZER)           │                 │              │           │           │
  │                      ├─eventSvc.cancelEvent(99)──────────►│                 │              │           │           │
  │                      │                 ├─findNonTerminalBookings(eventId=99)►│             │           │           │
  │                      │                 │◄─────────────────┤◄─List<Booking>──┤             │           │           │
  │                      │                 │                  │                 │              │           │           │
  │                      │                 │ for each booking:│                 │              │           │           │
  │                      │                 ├─stateMachine.send(EVENT_CANCELLED)──────────────►│           │           │
  │                      │                 │                  │            ├─if CONFIRMED:    │           │           │
  │                      │                 │                  │            │  CancelBookingAction          │           │
  │                      │                 │                  │            │     ├─stripe.refund(paymentIntentId)──────►│
  │                      │                 │                  │            │     ├─publish(EventCancelledNotif)──────►│           │
  │                      │                 │                  │            ├─if RESERVED:     │           │           │
  │                      │                 │                  │            │  ReleaseSeatsAction           │           │
  │                      │                 │                  │            ├─if PAYMENT_PENDING:           │           │
  │                      │                 │                  │            │  CancelPaymentSessionAction   │           │
  │                      │                 │                  │            │     ├─stripe.expire(sessionId)──────────►│
  │                      │                 ├─event.setStatus(ARCHIVED)──────────────────────────────────────────────►│
  │◄─200 OK──────────────┤◄────────────────┤                  │                 │              │           │           │
```

